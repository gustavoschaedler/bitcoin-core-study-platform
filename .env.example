# =============================================================================
#   Signet Core Study Platform — single source of truth
#   Copy to .env and adjust before running `docker compose up`.
# =============================================================================

# --- Branding / i18n ---------------------------------------------------------
APP_TITLE="Signet Core Study Platform"
DEFAULT_LANG=en-GB                              # pt-BR | en-GB

# --- Bitcoin Core image / runtime --------------------------------------------
BITCOIN_REPO=bitcoin/bitcoin
BITCOIN_VERSION=29
PYTHON_IMAGE=python:3.14-slim
NGINX_IMAGE=nginx:1.30-alpine

# --- Bitcoin Core RPC --------------------------------------------------------
# password : use BITCOIN_RPC_USER / BITCOIN_RPC_PASSWORD (default).
# cookie   : bitcoind generates ~/.bitcoin/signet/.cookie and clients read it
#            from the shared bitcoin-data volume; user/pass are then ignored.
BITCOIN_RPC_AUTH_MODE=password
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=replace_with_a_long_random_password
BITCOIN_RPC_URL=http://bitcoind:38332
BITCOIN_RPC_COOKIE_FILE=/bitcoind-data/signet/.cookie

# --- Faucet ------------------------------------------------------------------
FAUCET_AMOUNT_BTC=0.001
FAUCET_COOLDOWN_SECONDS=86400
FAUCET_MAX_PER_IP_PER_DAY=3
FAUCET_WALLET_NAME=faucet

# --- Wallet lab safety cap ---------------------------------------------------
MAX_WALLET_SEND_BTC=0.01

# --- Cloudflare Turnstile (optional CAPTCHA on /faucet) ----------------------
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- HTTP / proxy ------------------------------------------------------------
TRUST_PROXY_HEADERS=false
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# --- Container stats panel ---------------------------------------------------
# Requires compose.stats.yml (mounts the Docker socket read-only).
ENABLE_CONTAINER_STATS=false

# --- Terminal app ------------------------------------------------------------
TERMINAL_HOST_PORT=8182

# --- Rate limits (per minute) ------------------------------------------------
SEARCH_RATE_PER_MIN=6
MEMPOOL_DETAIL_RATE_PER_MIN=60
